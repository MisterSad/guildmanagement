{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:weekly",
    ":semanticCommits",
    ":dependencyDashboard"
  ],
  "labels": ["dependencies"],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": false
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": false,
      "groupName": "minor & patch updates"
    },
    {
      "matchPackageNames": ["next", "react", "react-dom"],
      "groupName": "Next.js core",
      "automerge": false
    },
    {
      "matchPackageNames": ["@supabase/supabase-js", "@supabase/ssr"],
      "groupName": "Supabase",
      "automerge": false
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"]
  }
}
