# ───────────────────────────────────────────────────────────────────────────
# RAD Management — variables d'environnement
# ───────────────────────────────────────────────────────────────────────────
# Copier ce fichier en `.env.local` (jamais committé) et remplir les valeurs.
# En production, configurer ces variables dans le dashboard Vercel
# (Production / Preview / Development séparés).
# ───────────────────────────────────────────────────────────────────────────

# ── Supabase (publique — sécurité dépend de la RLS) ───────────────────────
# URL du projet : Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Clé anon : Project Settings → API → anon public
# IMPORTANT : RLS DOIT être activée sur toutes les tables exposées via cette clé.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase (serveur uniquement — bypass RLS) ────────────────────────────
# À utiliser UNIQUEMENT côté serveur (Server Actions, Route Handlers).
# JAMAIS préfixer NEXT_PUBLIC_*.
# Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# ── App ─────────────────────────────────────────────────────────────────────
# URL canonique pour callbacks d'auth (ex: https://radmanagement.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Web Push (phase 7) ──────────────────────────────────────────────────────
# Générer avec : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@example.com
