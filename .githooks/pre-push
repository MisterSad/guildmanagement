#!/bin/bash
# Free local CI: validate before every push (no GitHub Actions, no billing).
# Enable with:  git config core.hooksPath .githooks
# (the SessionStart hook does this automatically for web sessions.)
# Bypass once with:  git push --no-verify
set -uo pipefail
ROOT="$(git rev-parse --show-toplevel)"
if ! command -v node >/dev/null 2>&1; then
  echo "pre-push: node not found; skipping validation."
  exit 0
fi
echo "pre-push: validating (node tools/check.js)…"
if node "$ROOT/tools/check.js"; then
  exit 0
else
  echo "pre-push: validation failed — push aborted. Fix issues or use --no-verify."
  exit 1
fi
